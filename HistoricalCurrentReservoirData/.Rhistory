scale_fill_manual(breaks = cPoolNames, values = c(pReds[3], pReds[5], pReds[7])) +
geom_hline(yintercept = dfPowellElevations2$ActiveStorageMAF, color = pBlues[5], linetype = "dashed", size =2) +
